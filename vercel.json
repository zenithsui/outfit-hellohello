{
  "rewrites": [
    {
      "source": "/_next/image",
      "destination": "/api/image"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        }
      ]
    }
  ]
}